# ORION — Environment Variables
# !! Never commit this file — it is in .gitignore !!

# Gemini API key (free tier) — for translation
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Database password
POSTGRES_PASSWORD=orion2024

# Grafana dashboard password
GRAFANA_PASSWORD=orion2024

# Scrape interval in ms (300000 = 5 min)
SCRAPE_INTERVAL_MS=300000

# Translation batch size (keep <=10 for Gemini free tier)
TRANSLATE_BATCH_SIZE=10
